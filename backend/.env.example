PORT=5050
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,https://mambu.sourabhk1967.workers.dev
PUBLIC_APP_URL=
JSON_LIMIT=80mb

# Abuse and cost controls (per IP address). These values allow a 100-request
# public-link burst while retaining a small amount of retry headroom.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=600
AUTH_RATE_LIMIT_MAX=200
AI_RATE_LIMIT_MAX=200

# Google Programmable Search Engine used by Computer mode.
GOOGLE_CSE_ID=
GOOGLE_CSE_URL=https://cse.google.com/cse

# GitHub connector. Register the OAuth app name as "Kyrovia GitHub Connector"
# so GitHub's authorization page uses Kyrovia branding.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_REDIRECT_URI=
GITHUB_OAUTH_SCOPE=repo read:user user:email
# Optional: provide a complete authorization URL instead of the fields above.
GITHUB_OAUTH_AUTHORIZE_URL=

# Legacy Google Fit REST integration. Google stopped accepting new Fit API
# registrations on May 1, 2024. These values work only for an existing,
# approved Google Cloud project with Fitness API access.
GOOGLE_FIT_CLIENT_ID=
GOOGLE_FIT_CLIENT_SECRET=
GOOGLE_FIT_REDIRECT_URI=http://localhost:5050/api/health/google-fit/callback
GOOGLE_FIT_RETURN_URL=http://localhost:5173
GOOGLE_FIT_SYNC_DAYS=30
# Use a separate long random secret in production. JWT_SECRET is the fallback.
GOOGLE_FIT_TOKEN_ENCRYPTION_KEY=

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=8h
JWT_ISSUER=kyrovia
JWT_AUDIENCE=kyrovia-client

# Firebase Google login. Keep the service account file on the backend only.
FIREBASE_PROJECT_ID=kyrovia-8dd36
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
# Optional alternative for hosting platforms:
# FIREBASE_SERVICE_ACCOUNT_JSON=

MAX_MESSAGE_LENGTH=8000
MAX_UPLOAD_BYTES=62914560
MAX_UPLOAD_FILES=12

# Persistent Kyrovia backend browser. Keep this false because the upstream service may block
# headless browsers with a human-verification page.
CHATGPT_URL=https://chatgpt.com/
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_USER_DATA_DIR=./playwright-profile
PLAYWRIGHT_TIMEOUT_MS=300000
PLAYWRIGHT_VIEWPORT_WIDTH=1365
PLAYWRIGHT_VIEWPORT_HEIGHT=900

# Each active generation receives an isolated browser tab and request session.
# This supports up to 100 simultaneous public-link messages.
CHAT_MAX_CONCURRENT_TABS=10
CHAT_PARALLEL_TABS=true
CHAT_QUEUE_MAX_PENDING=200
CHAT_QUEUE_WAIT_TIMEOUT_MS=3600000
PLAYWRIGHT_RECOVER_PROFILE_LOCK=true

# Optional persistent storage location on the hosting provider.
KYROVIA_DATA_DIR=./data

# WhatsApp / Baileys bridge.
WHATSAPP_AUTH_DIR=./data/whatsapp-auth
WHATSAPP_AUTO_RECONNECT=true
WHATSAPP_AUTO_REPLY=true
WHATSAPP_REPLY_GROUPS=false
